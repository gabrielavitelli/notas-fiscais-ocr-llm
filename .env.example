# Copie este arquivo para .env e preencha com suas chaves.
# O .env fica só no seu PC e não é enviado ao Git (segurança).
#
# Groq (recomendado, grátis): https://console.groq.com/keys
GROQ_API_KEY=gsk_sua_chave_aqui
